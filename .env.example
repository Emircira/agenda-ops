# ==========================================
# KARARGAH (AGENDA-OPS) ÇEVRE DEĞİŞKENLERİ
# ==========================================

# --- UYGULAMA AYARLARI ---
PROJECT_NAME="AgendaOps MVP"
DEBUG=True
API_V1_STR="/api/v1"
SECRET_KEY="128974981375981798412987591275981"
TZ=Europe/Istanbul

# Sistemin odaklanacağı ve koruyacağı ana siyasi figür
TARGET_PERSON="Siyasi Lider"

# --- VERİTABANI (PostgreSQL) ---
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agenda
POSTGRES_PORT=5432
# Asyncpg sürücüsüyle Docker içindeki 'db' servisine bağlanır
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/agenda

# --- REDIS & CELERY (İşçi Arılar) ---
REDIS_URL=redis://redis:6379/0

# --- DIŞ İSTİHBARAT (API ANAHTARLARI) ---
# YouTube Data API v3 Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# RapidAPI Key (X/Twitter verileri için). Production'da zorunludur.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com

# --- YAPAY ZEKA / LLM (GEMINI) ---
# OpenAI yerine Karargah'ın resmi beyni olarak Gemini kullanıyoruz
GEMINI_API_KEY=your_gemini_api_key_here
# auto: API hesabındaki generateContent destekli modeller arasından en iyi stabil modeli seçer.
# İlk tercih: gemini-2.5-flash. Manuel override gerekiyorsa örn. GEMINI_MODEL_NAME=gemini-2.5-flash-lite
GEMINI_MODEL_NAME=auto
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-2.0-flash,gemini-1.5-flash
USE_LLM=true